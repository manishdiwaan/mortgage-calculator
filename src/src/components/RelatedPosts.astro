---
interface Props {
  posts: { title: string; url: string }[];
}
const { posts } = Astro.props;
---

<div class="sticky top-24 bg-white dark:bg-slate-800 border border-border dark:border-slate-700 rounded-card p-5">
  <p class="font-semibold text-sm uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-3">
    Related articles
  </p>
  <ul class="space-y-3">
    {posts.map((post) => (
      <li>
        <a href={post.url} class="text-sm text-primary hover:underline leading-snug block">
          {post.title}
        </a>
      </li>
    ))}
  </ul>
</div>
