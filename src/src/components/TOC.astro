---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
const h2s = headings.filter((h) => h.depth === 2);
---

{h2s.length > 0 && (
  <nav class="bg-white dark:bg-slate-800 border border-border dark:border-slate-700 rounded-card p-5 mb-8">
    <p class="font-semibold text-sm uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-3">
      In this guide
    </p>
    <ol class="space-y-2 text-sm">
      {h2s.map((h, i) => (
        <li>
          <a href={`#${h.slug}`} class="text-primary hover:underline">
            {i + 1}. {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
