---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
const h2s = headings.filter((h) => h.depth === 2);
import Icon from './Icon.astro';
---

{h2s.length > 0 && (
  <details class="bg-white dark:bg-slate-800 border border-border dark:border-slate-700 rounded-card p-4 sm:p-5 mb-8 group" open>
    <summary class="font-semibold text-sm uppercase tracking-wide text-slate-500 dark:text-slate-400 cursor-pointer flex items-center justify-between list-none">
      In this guide
      <Icon name="expand_more" class="text-base text-slate-400 group-open:rotate-180 transition-transform" />
    </summary>
    <ol class="space-y-2 text-sm mt-3">
      {h2s.map((h, i) => (
        <li>
          <a href={`#${h.slug}`} class="text-primary hover:underline">
            {i + 1}. {h.text}
          </a>
        </li>
      ))}
    </ol>
  </details>
)}
