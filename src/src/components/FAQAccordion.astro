---
import SchemaOrg from './SchemaOrg.astro';
import { faqSchema } from '../utils/schema';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  includeSchema?: boolean;
}

const { faqs, includeSchema = true } = Astro.props;
---

<div class="space-y-3">
  {faqs.map((faq, i) => (
    <details class="group bg-white dark:bg-slate-800 border border-border dark:border-border-dark rounded-card overflow-hidden">
      <summary class="flex items-center justify-between cursor-pointer p-5 text-left font-medium text-slate-800 dark:text-slate-200 hover:bg-surface-light dark:hover:bg-slate-750 transition-colors">
        <span class="pr-4">{faq.question}</span>
        <span class="material-symbols-outlined text-slate-400 group-open:rotate-180 transition-transform shrink-0">
          expand_more
        </span>
      </summary>
      <div class="px-5 pb-5 text-slate-600 dark:text-slate-400 leading-relaxed text-[15px]">
        <p>{faq.answer}</p>
      </div>
    </details>
  ))}
</div>

{includeSchema && <SchemaOrg schema={faqSchema({ faqs })} />}
