---
interface Props {
  countryCode: string;
}
const { countryCode } = Astro.props;
---

<section class="mt-12 bg-primary rounded-card p-6 sm:p-8 text-center">
  <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">
    Ready to calculate your repayments?
  </h2>
  <p class="text-blue-100 mb-6 max-w-md mx-auto text-sm sm:text-base">
    Use our free mortgage calculator with live central bank rates and 250+ lenders.
  </p>
  <a
    href={`/calculator/?country=${countryCode}`}
    class="inline-flex items-center gap-2 bg-white text-primary font-semibold px-5 py-3 sm:px-6 rounded-button hover:bg-blue-50 transition-colors text-sm sm:text-base"
  >
    <span class="material-symbols-outlined text-lg">calculate</span>
    Open Calculator
  </a>
</section>
