---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { faqSchema, breadcrumbSchema } from '../utils/schema';
import { buildCanonical } from '../utils/seo';
import type { CountryMeta } from '../data/countries';

interface Props {
  country: CountryMeta;
  metaTitle: string;
  metaDescription: string;
  faqs: { question: string; answer: string; category: string }[];
}

const { country, metaTitle, metaDescription, faqs } = Astro.props;
const canonical = buildCanonical(`/${country.code}/faqs`);
const crumbs = [
  { name: 'Home', url: 'https://urmortgage.online/' },
  { name: country.name, url: `https://urmortgage.online/${country.code}/` },
  { name: 'FAQs', url: canonical },
];

const categories = [...new Set(faqs.map((f) => f.category))];
const grouped = categories.map((cat) => ({
  category: cat,
  label: cat.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
  items: faqs.filter((f) => f.category === cat),
}));
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={canonical}
  schemas={[breadcrumbSchema(crumbs), faqSchema(faqs)]}
>
  <div class="max-w-page mx-auto px-4 py-8">
    <Breadcrumbs items={crumbs} />
    <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-8">
      {country.name} Mortgage & Property FAQs
    </h1>

    {grouped.map((group) => (
      <section class="mb-10">
        <h2 class="text-xl font-semibold text-primary dark:text-blue-400 mb-4">{group.label}</h2>
        {group.items.map((faq) => (
          <details class="mb-3 bg-white dark:bg-slate-800 border border-border dark:border-slate-700 rounded-card p-4">
            <summary class="font-medium cursor-pointer">{faq.question}</summary>
            <p class="mt-3 text-slate-600 dark:text-slate-300 leading-relaxed">{faq.answer}</p>
          </details>
        ))}
      </section>
    ))}
  </div>
</BaseLayout>
