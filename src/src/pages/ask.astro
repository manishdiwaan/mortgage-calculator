---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PILOT_COUNTRIES } from '../data/countries';
import { getCollection } from 'astro:content';
import { breadcrumbSchema } from '../utils/schema';
import { buildCanonical } from '../utils/seo';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const canonical = buildCanonical('/ask');
const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Ask URMortgage', url: canonical },
];

const allFaqEntries = await getCollection('faqs', (e) => e.data.published);
const knowledgeBase = allFaqEntries.map((entry) => ({
  country: entry.data.country,
  count: entry.data.faqs.length,
}));

// Turnstile site key — set via environment or placeholder (replaced at build)
const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY || '';
---

<BaseLayout
  title="Ask URMortgage — Mortgage & Property Q&A"
  description="Get instant answers to your mortgage and property questions across 23 countries. AI-powered chat backed by expert guides."
  canonical={canonical}
  schemas={[breadcrumbSchema(crumbs)]}
>
  <!-- Turnstile script (only loaded if site key is configured) -->
  {TURNSTILE_SITE_KEY && (
    <script slot="head" src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <div class="max-w-page mx-auto px-4 sm:px-6 py-8">
    <Breadcrumbs items={crumbs} />

    <div class="text-center mb-8">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        <span class="text-primary">Ask</span> URMortgage
      </h1>
      <p class="text-slate-500 max-w-lg mx-auto text-sm sm:text-base">
        AI-powered answers about mortgages and property across 23 countries. Ask anything.
      </p>
    </div>

    <!-- Chat -->
    <div class="max-w-2xl mx-auto mb-12">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-md overflow-hidden">
        <div id="chat-messages" class="h-[240px] overflow-y-auto p-5 space-y-3">
          <div class="flex gap-3">
            <div class="w-7 h-7 rounded-full bg-primary flex items-center justify-center shrink-0">
              <span class="text-white text-[10px] font-bold">UR</span>
            </div>
            <div class="bg-surface rounded-2xl rounded-tl-md px-4 py-2.5 max-w-[85%]">
              <p class="text-sm text-slate-700">
                Hi! I can answer questions about mortgages, deposits, stamp duty, taxes, and buying property across 23 countries — Australia, UK, US, UAE, Singapore, India, Canada, and more. What would you like to know?
              </p>
            </div>
          </div>
        </div>
        <div class="border-t border-slate-200 p-3 flex gap-2">
          <input
            id="chat-input"
            type="text"
            placeholder="e.g., What's the max LTV for expats in UAE?"
            maxlength="500"
            class="flex-1 px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
          />
          <button
            id="chat-send"
            class="bg-primary text-white px-4 py-2.5 rounded-xl text-sm hover:bg-blue-700 transition-colors shrink-0"
          >
            <span class="material-symbols-outlined text-lg">send</span>
          </button>
        </div>
      </div>
      <!-- Turnstile widget (invisible) -->
      {TURNSTILE_SITE_KEY && (
        <div
          id="turnstile-widget"
          class="cf-turnstile"
          data-sitekey={TURNSTILE_SITE_KEY}
          data-theme="light"
          data-size="invisible"
        ></div>
      )}
      <p class="text-[11px] text-slate-400 text-center mt-2">AI-powered. Based on URMortgage guides only. Not financial advice.</p>
    </div>

    <!-- Country FAQ Cards -->
    <h2 class="text-2xl font-bold text-slate-900 text-center mb-2">Browse FAQs by country</h2>
    <p class="text-slate-500 text-center mb-8 text-sm">Or explore country-specific questions directly</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 md:gap-6 max-w-3xl mx-auto">
      {PILOT_COUNTRIES.map((country) => {
        const entry = knowledgeBase.find((k) => k.country === country.code);
        return (
          <a
            href={`/${country.code}/faqs/`}
            class="group relative flex flex-col items-center gap-3 bg-white border border-slate-200 rounded-2xl p-4 sm:p-6 hover:border-primary hover:shadow-xl hover:shadow-primary/10 transition-all duration-300 hover:-translate-y-1"
          >
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/5 to-blue-50 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="relative text-4xl md:text-5xl group-hover:scale-110 transition-transform duration-300">{country.flag}</span>
            <div class="relative text-center">
              <h3 class="text-xs sm:text-sm font-bold text-slate-800 group-hover:text-primary transition-colors">{country.name}</h3>
              <p class="text-xs text-slate-400 mt-0.5">{entry?.count || 0} FAQs</p>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <script is:inline>
  (function() {
    var msgs = document.getElementById('chat-messages');
    var input = document.getElementById('chat-input');
    var btn = document.getElementById('chat-send');
    var turnstileWidget = document.querySelector('.cf-turnstile');
    var hasTurnstile = !!turnstileWidget;

    function addMsg(html, isUser) {
      var w = document.createElement('div');
      w.className = 'flex gap-3' + (isUser ? ' justify-end' : '');
      if (isUser) {
        w.innerHTML = '<div class="bg-primary text-white rounded-2xl rounded-tr-md px-4 py-2.5 max-w-[85%]"><p class="text-sm">' + escHtml(html) + '</p></div>';
      } else {
        w.innerHTML = '<div class="w-7 h-7 rounded-full bg-primary flex items-center justify-center shrink-0"><span class="text-white text-[10px] font-bold">UR</span></div><div class="bg-surface rounded-2xl rounded-tl-md px-4 py-2.5 max-w-[85%]"><div class="text-sm text-slate-700">' + html + '</div></div>';
      }
      msgs.appendChild(w);
      msgs.scrollTop = msgs.scrollHeight;
    }

    function escHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    function showTyping() {
      var w = document.createElement('div');
      w.className = 'flex gap-3';
      w.id = 'typing';
      w.innerHTML = '<div class="w-7 h-7 rounded-full bg-primary flex items-center justify-center shrink-0"><span class="text-white text-[10px] font-bold">UR</span></div><div class="bg-surface rounded-2xl rounded-tl-md px-4 py-2.5"><p class="text-sm text-slate-400">Thinking...</p></div>';
      msgs.appendChild(w);
      msgs.scrollTop = msgs.scrollHeight;
    }

    function removeTyping() {
      var t = document.getElementById('typing');
      if (t) t.remove();
    }

    function getTurnstileToken() {
      return new Promise(function(resolve) {
        if (!hasTurnstile || typeof turnstile === 'undefined') {
          resolve(null);
          return;
        }
        try {
          turnstile.execute('.cf-turnstile', {
            callback: function(token) { resolve(token); },
            'error-callback': function() { resolve(null); }
          });
        } catch(e) {
          resolve(null);
        }
      });
    }

    async function send() {
      var q = input.value.trim();
      if (!q || q.length < 3) return;
      if (q.length > 500) {
        addMsg('Your question is too long. Please keep it under 500 characters.', false);
        return;
      }

      addMsg(q, true);
      input.value = '';
      btn.disabled = true;
      input.disabled = true;
      showTyping();

      try {
        // Get Turnstile token if available
        var turnstileToken = await getTurnstileToken();

        var payload = { question: q };
        if (turnstileToken) payload.turnstileToken = turnstileToken;

        var res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var data = await res.json();
        removeTyping();

        if (res.status === 429) {
          addMsg("You're sending too many questions. Please wait a moment before asking again.", false);
        } else if (res.status === 403) {
          addMsg("Bot verification failed. Please refresh the page and try again.", false);
        } else if (data.error) {
          addMsg("Sorry, I'm having trouble right now. Try browsing our <a href='/' class='text-primary underline'>country guides</a> instead.", false);
        } else {
          var answer = escHtml(data.answer).replace(/\n/g, '<br>');
          addMsg(answer, false);
        }
      } catch (err) {
        removeTyping();
        addMsg("Sorry, something went wrong. Try <a href='/' class='text-primary underline'>browsing our guides</a> instead.", false);
      }

      btn.disabled = false;
      input.disabled = false;
      input.focus();

      // Reset Turnstile for next request
      if (hasTurnstile && typeof turnstile !== 'undefined') {
        try { turnstile.reset('.cf-turnstile'); } catch(e) {}
      }
    }

    btn.addEventListener('click', send);
    input.addEventListener('keydown', function(e) { if (e.key === 'Enter') send(); });
  })();
  </script>
</BaseLayout>
