---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PILOT_COUNTRIES } from '../data/countries';
import AdSlot from '../components/AdSlot.astro';
import { organizationSchema, websiteSchema, softwareApplicationSchema } from '../utils/schema';

const schemas = [organizationSchema(), websiteSchema(), softwareApplicationSchema()];
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="URMortgage — Global Mortgage Calculator & Property Guides"
  description="Free mortgage calculator for 29 countries with 250+ lenders and central bank rate tracking. Property buying guides, mortgage guides, and FAQs."
  canonical="https://urmortgage.online/"
  schemas={schemas}
>
  <!-- Hero: Split layout -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary via-blue-700 to-blue-900 text-white">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-blue-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-page mx-auto px-6 py-14 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <!-- Left: Text -->
        <div>
          <p class="text-blue-200 text-xs font-semibold tracking-widest uppercase mb-4">29 countries · 250+ lenders · Free</p>
          <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight tracking-tight">
            Your mortgage,<br />anywhere in<br class="hidden md:block" /> the world
          </h1>
          <p class="text-base md:text-lg text-blue-100 leading-relaxed max-w-md">
            Calculate repayments, compare lenders, and read country-specific guides — all in one place.
          </p>
        </div>
        <!-- Right: Calculator Preview -->
        <div class="hidden md:block">
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-5 shadow-2xl">
            <div class="bg-white rounded-xl p-4 text-slate-800">
              <div class="flex items-center gap-2 mb-3">
                <Icon name="calculate" class="text-primary text-lg" />
                <span class="font-bold text-sm text-primary">Mortgage Calculator</span>
              </div>
              <div class="space-y-2">
                <div class="flex justify-between text-xs"><span class="text-slate-500">Property Price</span><span class="font-semibold">$600,000</span></div>
                <div class="h-2 bg-slate-100 rounded-full"><div class="h-2 bg-primary rounded-full w-3/4"></div></div>
                <div class="flex justify-between text-xs"><span class="text-slate-500">Deposit</span><span class="font-semibold">$120,000</span></div>
                <div class="h-2 bg-slate-100 rounded-full"><div class="h-2 bg-secondary rounded-full w-1/5"></div></div>
                <div class="flex justify-between text-xs"><span class="text-slate-500">Interest Rate</span><span class="font-semibold">6.15%</span></div>
              </div>
              <div class="mt-4 pt-3 border-t border-slate-100">
                <div class="text-center">
                  <p class="text-xs text-slate-500">Monthly Repayment</p>
                  <p class="text-2xl font-bold text-primary">$2,924</p>
                </div>
              </div>
            </div>
            <div class="mt-3 grid grid-cols-3 gap-2">
              <div class="bg-white/10 rounded-lg px-2 py-2 text-center">
                <p class="text-[10px] text-blue-200">Total Interest</p>
                <p class="text-xs font-bold">$572,640</p>
              </div>
              <div class="bg-white/10 rounded-lg px-2 py-2 text-center">
                <p class="text-[10px] text-blue-200">Loan Term</p>
                <p class="text-xs font-bold">30 years</p>
              </div>
              <div class="bg-white/10 rounded-lg px-2 py-2 text-center">
                <p class="text-[10px] text-blue-200">Total Cost</p>
                <p class="text-xs font-bold">$1.05M</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Centered CTA -->
      <div class="text-center mt-10">
        <a
          href="/calculator/"
          class="inline-flex items-center gap-3 bg-white text-primary font-bold px-6 py-3 sm:px-8 sm:py-4 rounded-xl text-base sm:text-lg hover:bg-blue-50 hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5"
        >
          <Icon name="calculate" class="text-2xl" />
          Open Calculator
        </a>
      </div>
    </div>
  </section>

  <!-- Country Selector — tighter spacing to hero -->
  <section class="max-w-page mx-auto px-6 pt-10 pb-16 md:pt-14 md:pb-20">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">
        Choose your country
      </h2>
      <p class="text-slate-500 text-base max-w-lg mx-auto">
        Property guides, mortgage guides, and FAQs tailored to your market.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 md:gap-6 max-w-3xl mx-auto">
      {PILOT_COUNTRIES.map((country) => (
        <a
          href={`/${country.code}/`}
          class="group relative flex flex-col items-center gap-3 bg-white border border-slate-200 rounded-2xl p-4 sm:p-6 md:p-10 hover:border-primary hover:shadow-2xl hover:shadow-primary/10 transition-all duration-300 hover:-translate-y-1"
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/5 to-blue-50 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <span class="relative text-4xl sm:text-5xl md:text-7xl group-hover:scale-110 transition-transform duration-300 drop-shadow-sm">
            {country.flag}
          </span>
          <div class="relative text-center">
            <h3 class="text-xs sm:text-sm md:text-lg font-bold text-slate-800 group-hover:text-primary transition-colors duration-300">
              {country.name}
            </h3>
            <p class="text-xs text-slate-400 mt-0.5">{country.currency}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Ad: blended between sections -->
  <div class="max-w-page mx-auto px-6">
    <AdSlot slot="home-mid" class="rounded-xl overflow-hidden" />
  </div>

  <!-- What You Get -->
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-page mx-auto px-6 py-14 md:py-16">
      <h2 class="text-2xl font-bold text-center text-slate-900 mb-10">
        What's inside each country hub
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <Icon name="menu_book" class="text-xl text-primary" />
          </div>
          <h3 class="font-semibold text-sm text-slate-800 mb-1">Buying Guides</h3>
          <p class="text-xs text-slate-500">Step-by-step for each market</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mx-auto mb-3">
            <Icon name="account_balance" class="text-xl text-secondary" />
          </div>
          <h3 class="font-semibold text-sm text-slate-800 mb-1">Mortgage Guides</h3>
          <p class="text-xs text-slate-500">Rates, lenders, loan types</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <Icon name="help" class="text-xl text-primary" />
          </div>
          <h3 class="font-semibold text-sm text-slate-800 mb-1">50+ FAQs</h3>
          <p class="text-xs text-slate-500">Common questions answered</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mx-auto mb-3">
            <Icon name="calculate" class="text-xl text-secondary" />
          </div>
          <h3 class="font-semibold text-sm text-slate-800 mb-1">Calculator</h3>
          <p class="text-xs text-slate-500">250+ lenders, live rates</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
