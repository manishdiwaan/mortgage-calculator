---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { PILOT_COUNTRIES, getCountryByCode } from '../../../data/countries';
import { getCollection } from 'astro:content';
import { buildCanonical } from '../../../utils/seo';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return PILOT_COUNTRIES.map((c) => ({
    params: { country: c.code },
  }));
};

const { country: countryCode } = Astro.params;
const country = getCountryByCode(countryCode as string)!;
const canonical = buildCanonical(`/${countryCode}/blog`);

const allBlogs = await getCollection('blogs', (entry) =>
  entry.data.country === countryCode && entry.data.published
);
---

<BaseLayout
  title={`${country.name} Property & Mortgage Blog | URMortgage`}
  description={`Tips, guides, and insights about buying property and getting a mortgage in ${country.name}.`}
  canonical={canonical}
>
  <div class="max-w-[var(--max-width-page)] mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { name: 'Home', url: '/' },
      { name: country.name, url: `/${countryCode}/` },
      { name: 'Blog', url: canonical },
    ]} />

    <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-3">
      {country.flag} {country.name} Blog
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-10">
      Articles about buying property and getting a mortgage in {country.name}.
    </p>

    {allBlogs.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {allBlogs.map((blog) => (
          <a href={`/${countryCode}/blog/${blog.data.slug}/`} class="bg-white dark:bg-slate-800 border border-[var(--color-border)] dark:border-slate-700 rounded-[var(--radius-card)] p-5 hover:shadow-md hover:border-[var(--color-primary)] transition-all">
            <h2 class="font-semibold text-lg mb-2">{blog.data.title}</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">{blog.data.metaDescription}</p>
            <span class="text-xs text-[var(--color-primary)] font-medium">Read more →</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="bg-[var(--color-surface)] dark:bg-slate-800 rounded-[var(--radius-card)] p-8 text-center">
        <p class="text-slate-600 dark:text-slate-400">
          Articles are being published. Check back soon, or explore our guides:
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-6">
          <a href={`/${countryCode}/property-buying-guide/`} class="text-[var(--color-primary)] font-medium hover:underline">
            Property Buying Guide
          </a>
          <a href={`/${countryCode}/mortgage-guide/`} class="text-[var(--color-primary)] font-medium hover:underline">
            Mortgage Guide
          </a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
