---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { PILOT_COUNTRIES, getCountryByCode } from '../../data/countries';
import { getCollection } from 'astro:content';
import { breadcrumbSchema } from '../../utils/schema';
import { buildCanonical } from '../../utils/seo';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return PILOT_COUNTRIES.map((c) => ({
    params: { country: c.code },
  }));
};

const { country: countryCode } = Astro.params;
const country = getCountryByCode(countryCode as string)!;
const canonical = buildCanonical(`/${countryCode}`);
const crumbs = [
  { name: 'Home', url: 'https://urmortgage.online/' },
  { name: country.name, url: canonical },
];

// Get published blogs for this country
const allBlogs = await getCollection('blogs', (entry) =>
  entry.data.country === countryCode && entry.data.published
);
---

<BaseLayout
  title={`${country.name} Mortgage & Property Guide 2026 | URMortgage`}
  description={`Complete mortgage and property buying resource for ${country.name}. Calculator, guides, FAQs, and lender comparisons in ${country.currency}.`}
  canonical={canonical}
  schemas={[breadcrumbSchema(crumbs)]}
>
  <div class="max-w-page mx-auto px-6 py-8">
    <Breadcrumbs items={crumbs} />

    <!-- Country Header -->
    <div class="flex items-center gap-5 mb-8">
      <span class="text-6xl">{country.flag}</span>
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-slate-900">{country.name}</h1>
        <p class="text-slate-500 mt-1">{country.centralBank} · {country.currency}</p>
      </div>
    </div>

    <p class="text-lg text-slate-600 max-w-2xl leading-relaxed mb-10">
      Everything you need to buy property and get a mortgage in {country.name}.
      Step-by-step guides, FAQs, lender comparisons, and a free calculator.
    </p>

    <!-- Pillar Guides -->
    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">auto_stories</span>
      Comprehensive Guides
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
      <a href={`/${countryCode}/property-buying-guide/`} class="group bg-white border border-slate-200 rounded-2xl p-6 hover:border-primary hover:shadow-lg transition-all duration-300">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-xl text-primary">real_estate_agent</span>
          </div>
          <div>
            <h3 class="font-bold text-slate-800 group-hover:text-primary transition-colors">Complete Property Buying Guide</h3>
            <p class="text-sm text-slate-500 mt-1">Step-by-step process for buying property in {country.name}.</p>
          </div>
        </div>
      </a>
      <a href={`/${countryCode}/mortgage-guide/`} class="group bg-white border border-slate-200 rounded-2xl p-6 hover:border-secondary hover:shadow-lg transition-all duration-300">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center shrink-0 group-hover:bg-secondary/20 transition-colors">
            <span class="material-symbols-outlined text-xl text-secondary">account_balance</span>
          </div>
          <div>
            <h3 class="font-bold text-slate-800 group-hover:text-secondary transition-colors">Complete Mortgage Guide</h3>
            <p class="text-sm text-slate-500 mt-1">Rates, loan types, lenders, and how to get approved.</p>
          </div>
        </div>
      </a>
    </div>

    <!-- Blog Posts -->
    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">article</span>
      Articles & Guides
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-10">
      {allBlogs.length > 0 ? allBlogs.map((blog, i) => (
        <a href={`/${countryCode}/blog/${blog.data.slug}/`} class="group flex items-center gap-4 bg-white border border-slate-200 rounded-xl px-5 py-4 hover:border-primary/50 hover:bg-primary/5 transition-all duration-200">
          <span class="text-xs font-bold text-primary/40 group-hover:text-primary transition-colors w-6">{String(i + 1).padStart(2, '0')}</span>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-sm text-slate-800 group-hover:text-primary transition-colors truncate">{blog.data.title}</h3>
            <p class="text-xs text-slate-400 mt-0.5 truncate">{blog.data.metaDescription}</p>
          </div>
          <span class="material-symbols-outlined text-slate-300 group-hover:text-primary text-base transition-colors shrink-0">arrow_forward</span>
        </a>
      )) : (
        <div class="col-span-2 bg-slate-50 rounded-xl p-6 text-center text-slate-500">
          Articles coming soon for {country.name}.
        </div>
      )}
    </div>

    <!-- FAQs & Tools -->
    <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">build</span>
      Tools & Resources
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
      <a href={`/${countryCode}/faqs/`} class="group bg-white border border-slate-200 rounded-xl p-5 hover:border-primary/50 hover:shadow-md transition-all duration-200">
        <span class="material-symbols-outlined text-2xl text-primary mb-3 block">help</span>
        <h3 class="font-bold text-slate-800 group-hover:text-primary transition-colors">{country.name} FAQs</h3>
        <p class="text-sm text-slate-500 mt-1">50+ answers to common questions</p>
      </a>
      <a href={`/calculator/?country=${country.iso.toLowerCase()}`} class="group bg-white border border-slate-200 rounded-xl p-5 hover:border-secondary/50 hover:shadow-md transition-all duration-200">
        <span class="material-symbols-outlined text-2xl text-secondary mb-3 block">calculate</span>
        <h3 class="font-bold text-slate-800 group-hover:text-secondary transition-colors">Mortgage Calculator</h3>
        <p class="text-sm text-slate-500 mt-1">Calculate repayments in {country.currencySymbol}{country.currency}</p>
      </a>
      <a href={`/${countryCode}/blog/`} class="group bg-white border border-slate-200 rounded-xl p-5 hover:border-primary/50 hover:shadow-md transition-all duration-200">
        <span class="material-symbols-outlined text-2xl text-primary mb-3 block">library_books</span>
        <h3 class="font-bold text-slate-800 group-hover:text-primary transition-colors">All Articles</h3>
        <p class="text-sm text-slate-500 mt-1">Browse the full blog</p>
      </a>
    </div>
  </div>
</BaseLayout>
